{
  "name": "triage-mcp-server",
  "version": "1.0.0",
  "description": "Read-only MCP server (and optional web UI) for Azure DevOps work item triage",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "web": "npm run build && node dist/web-server.js",
    "web:dev": "node dist/web-server.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "express": "^4.19.2",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "@types/node-fetch": "^2.6.11",
    "typescript": "^5.4.0"
  }
}
